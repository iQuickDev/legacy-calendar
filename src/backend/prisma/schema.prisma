generator client {
  provider   = "prisma-client"
  output     = "./generated"
  engineType = "client"
  runtime    = "bun"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         Int              @id @default(autoincrement())
  username                   String           @unique
  password                   String
  profilePicture             String?
  invitations                Attendance[]
  hostedEvents               Event[]          @relation("EventHost")
  fcmTokens                  FcmToken[]
  chatMutes                  ChatMute[]
  rideAssignmentsAsDriver    RideAssignment[] @relation("RideAssignmentDriver")
  rideAssignmentsAsPassenger RideAssignment[] @relation("RideAssignmentPassenger")
  isAdmin                    Boolean          @default(false)
  chatMessages               ChatMessage[]
  chatReactions              ChatReaction[]
  auditLogEntriesAsActor     AuditLogEntry[]  @relation("AuditLogActor")
  auditLogEntriesAsImpersonator AuditLogEntry[] @relation("AuditLogImpersonator")
}

model FcmToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id                    Int              @id @default(autoincrement())
  title                 String
  color                 String?          @default("#ffffff")
  description           String?
  location              String?
  startTime             DateTime
  endTime               DateTime?
  hostId                Int
  isOpen                Boolean          @default(true)
  hasAlcohol            Boolean          @default(false)
  hasFood               Boolean          @default(false)
  hasSleep              Boolean          @default(false)
  hasWeed               Boolean          @default(false)
  alcoholPrice          Float?
  beerPrice             Float?
  foodPrice             Float?
  hasBeer               Boolean          @default(false)
  sleepPrice            Float?
  weedPrice             Float?
  isPrivate             Boolean          @default(false)
  participationDeadline DateTime?
  participants          Attendance[]
  host                  User             @relation("EventHost", fields: [hostId], references: [id])
  rideAssignments       RideAssignment[]
  chatMessages          ChatMessage[]
  chatMutes             ChatMute[]
  auditLogEntries       AuditLogEntry[]
}

model Attendance {
  id            Int           @id @default(autoincrement())
  userId        Int
  eventId       Int
  createdAt     DateTime      @default(now())
  status        InviteStatus  @default(PENDING)
  wantsAlcohol  Boolean       @default(false)
  wantsFood     Boolean       @default(false)
  wantsSleep    Boolean       @default(false)
  wantsWeed     Boolean       @default(false)
  wantsBeer     Boolean       @default(false)
  transportMode TransportMode @default(NEEDS_RIDE)
  vehicleSeats  Int           @default(0)
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@unique([userId, eventId])
}

model RideAssignment {
  id          Int   @id @default(autoincrement())
  eventId     Int
  driverId    Int
  passengerId Int
  driver      User  @relation("RideAssignmentDriver", fields: [driverId], references: [id], onDelete: Cascade)
  event       Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  passenger   User  @relation("RideAssignmentPassenger", fields: [passengerId], references: [id], onDelete: Cascade)

  @@unique([eventId, passengerId])
  @@index([eventId, driverId])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum TransportMode {
  NEEDS_RIDE
  SELF
  DRIVER
}

enum ChatMediaType {
  image
  gif
  video
  audio
}

model ChatMessage {
  id        Int             @id @default(autoincrement())
  eventId   Int
  authorId  Int
  text      String?
  mediaUrl  String?
  mediaType ChatMediaType?
  isPinned  Boolean         @default(false)
  isEdited  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  event     Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author    User           @relation(fields: [authorId], references: [id])
  reactions ChatReaction[]

  @@index([eventId, createdAt])
  @@index([eventId, isPinned, createdAt])
}

model ChatReaction {
  id        Int    @id @default(autoincrement())
  messageId Int
  userId    Int
  emoji     String

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
}

model ChatMute {
  id      Int   @id @default(autoincrement())
  userId  Int
  eventId Int

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
}

model AuditLogEntry {
  id             Int        @id @default(autoincrement())
  eventId        Int
  actorId        Int
  impersonatorId  Int?
  actionType     ActionType
  payloadDiff    Json
  createdAt      DateTime   @default(now())

  event          Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  actor          User       @relation("AuditLogActor", fields: [actorId], references: [id])
  impersonator   User?      @relation("AuditLogImpersonator", fields: [impersonatorId], references: [id])

  @@index([eventId, createdAt])
}

enum ActionType {
  EVENT_CREATED
  EVENT_UPDATED
  EVENT_DELETED
  PARTICIPANT_JOINED
  PARTICIPANT_DECLINED
  PARTICIPANT_REMOVED
  PARTICIPANT_UPDATED
  PARTICIPANT_INVITED
  RIDE_ASSIGNED
  RIDE_UNASSIGNED
}
